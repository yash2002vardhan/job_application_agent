# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Your resume (.pdf, .txt, or .md)
RESUME_PATH=./resume.pdf

# Job-application MCP server — set EITHER MCP_COMMAND or MCP_URL.
# MCP_COMMAND=npx -y some-job-mcp-server
MCP_URL=https://hatch-one.vercel.app/api/mcp
MCP_TRANSPORT=streamable-http   # or "sse"

# Candidate profile (fields this application needs beyond the resume).
CANDIDATE_NAME=
CANDIDATE_EMAIL=
CANDIDATE_PHONE=
GITHUB_URL=
LINKEDIN_URL=
# Link to your agentic project / agent harness (e.g. OpenClaw setup):
AGENTIC_PROJECT_URL=
# Optional: a hosted URL of your resume (used instead of / alongside resume text):
RESUME_URL=
